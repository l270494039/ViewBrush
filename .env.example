# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional: Override the Gemini image editing model if your account uses a different one.
GEMINI_IMAGE_EDIT_MODEL="gemini-2.5-flash-image"

# Optional: Set to "true" to bypass real Gemini image generation and always use
# built-in mock previews. Useful for demos, flow testing, and Render setups
# without image-generation quota.
VIEWBRUSH_FORCE_MOCK_GENERATION="false"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_SUPPORT_EMAIL: Used by the create page feedback entry so customers can send
# preview adjustment requests with their current selections prefilled.
VITE_SUPPORT_EMAIL="support@example.com"
